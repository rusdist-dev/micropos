# ----------------------------------------------------------------------------
# MicroPOS - Contoh konfigurasi PRODUCTION
# Salin ke `.env`, isi nilai rahasia, lalu jalankan `php artisan key:generate`.
# ----------------------------------------------------------------------------

APP_NAME=MicroPOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://pos.example.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (MySQL 8) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=micropos
DB_USERNAME=micropos
DB_PASSWORD=

# --- Session & Cache ---
# Default 'file' (tanpa setup tambahan). Untuk multi-server gunakan 'database'
# (jalankan `php artisan session:table && php artisan migrate`) atau 'redis'.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# --- Mail (opsional) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@pos.example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
